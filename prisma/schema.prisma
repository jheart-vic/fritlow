// Prisma schema — the single source of truth for the database structure.
// Each `model` becomes a table in Postgres. Run `npm run db:migrate` after
// changing this file to generate + apply a SQL migration.

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// Roles a user can hold inside a workspace (RBAC).
enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

// The project lifecycle shown on the Projects screen:
// Draft → Discovery → Blueprint Complete → Launched.
enum ProjectStatus {
  DRAFT
  DISCOVERY
  BLUEPRINT_COMPLETE
  LAUNCHED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  fullName     String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships     WorkspaceMember[]
  refreshTokens   RefreshToken[]
  passwordResets  PasswordResetToken[]
  createdProjects Project[]
  decisions       DecisionLog[]
}

// Tenancy root: every project will live inside a workspace.
// Users get a personal workspace automatically at registration.
model Workspace {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  WorkspaceMember[]
  projects Project[]
}

enum AiCallStatus {
  SUCCESS
  ERROR
}

// Audit log of every AI call (PRD: log all interactions end to end).
// Deliberately relation-free: log rows must survive user/project deletion.
model AiInteraction {
  id           String       @id @default(uuid())
  feature      String // which product feature made the call, e.g. "discovery.follow_up"
  provider     String // "anthropic", later "openai" | "gemini"
  model        String
  systemPrompt String?
  userPrompt   String
  response     String?
  inputTokens  Int?
  outputTokens Int?
  latencyMs    Int
  status       AiCallStatus
  error        String?
  userId       String?
  projectId    String?
  createdAt    DateTime     @default(now())

  @@index([feature, createdAt])
}

enum DiscoveryStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

// One guided interview per project (the signature feature). The session
// tracks lifecycle; the answers hold the founder's actual input.
model DiscoverySession {
  id          String          @id @default(uuid())
  status      DiscoveryStatus @default(ACTIVE)
  startedAt   DateTime        @default(now())
  completedAt DateTime?

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String  @unique // one session per project in V1

  answers DiscoveryAnswer[]
}

// One answer per question per session. `answer` is JSONB: today it's
// { "text": "..." }, later AI follow-ups can add structure without a
// schema migration — exactly what JSONB is for.
model DiscoveryAnswer {
  id           String   @id @default(uuid())
  questionId   String // stable key from the question bank (e.g. "problem.who")
  questionText String // snapshot, so old answers survive question-bank edits
  module       String // interview module, e.g. "problem", "customer"
  answer       Json
  answeredAt   DateTime @default(now())

  session   DiscoverySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String

  // Answering the same question again replaces the answer (upsert target).
  @@unique([sessionId, questionId])
}

enum BlueprintStatus {
  GENERATING
  READY
  FAILED
}

// The Living Blueprint — one per project, generated from discovery answers,
// then continuously edited. Content lives in sections, not here.
model Blueprint {
  id          String          @id @default(uuid())
  status      BlueprintStatus @default(GENERATING)
  generatedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String  @unique

  sections BlueprintSection[]
}

// One editable section of the blueprint. `content` is JSONB — today
// { "markdown": "..." }; richer structures (user stories, metrics tables)
// can arrive later without a migration.
model BlueprintSection {
  id        String   @id @default(uuid())
  key       String // stable key, e.g. "problem_statement"
  title     String
  order     Int
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  blueprint   Blueprint @relation(fields: [blueprintId], references: [id], onDelete: Cascade)
  blueprintId String

  @@unique([blueprintId, key])
}

enum DecisionStatus {
  ACTIVE
  REVISED
  REVERSED
}

// The Decision Log: every major product decision as a first-class object,
// with its reasoning — so the team remembers WHY, months later.
model DecisionLog {
  id        String         @id @default(uuid())
  title     String // "Use Stripe for payments"
  reasoning String
  status    DecisionStatus @default(ACTIVE)
  decidedAt DateTime       @default(now())
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  createdBy   User    @relation(fields: [createdById], references: [id])
  createdById String

  @@index([projectId])
}

// The core domain object: everything in Fritlow lives inside a project,
// and every project lives inside a workspace (the tenancy rule).
model Project {
  id          String        @id @default(uuid())
  name        String
  oneLineIdea String
  category    String?
  status      ProjectStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdById String

  discoverySession DiscoverySession?
  blueprint        Blueprint?
  decisions        DecisionLog[]

  @@index([workspaceId])
}

// Join table between User and Workspace, carrying the user's role.
model WorkspaceMember {
  id          String        @id @default(uuid())
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  // A user can only be a member of a given workspace once.
  @@unique([userId, workspaceId])
}

// Long-lived session tokens. Only a SHA-256 hash is stored — if the DB
// leaks, the tokens themselves remain unusable.
model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId])
}

// Single-use tokens for the forgot-password flow, also stored hashed.
model PasswordResetToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId])
}
