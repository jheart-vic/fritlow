// Prisma schema — the single source of truth for the database structure.
// Each `model` becomes a table in Postgres. Run `npm run db:migrate` after
// changing this file to generate + apply a SQL migration.

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// Roles a user can hold inside a workspace (RBAC).
enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

// The project lifecycle shown on the Projects screen:
// Draft → Discovery → Blueprint Complete → Launched.
enum ProjectStatus {
  DRAFT
  DISCOVERY
  BLUEPRINT_COMPLETE
  LAUNCHED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  fullName     String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships     WorkspaceMember[]
  refreshTokens   RefreshToken[]
  passwordResets  PasswordResetToken[]
  createdProjects Project[]
}

// Tenancy root: every project will live inside a workspace.
// Users get a personal workspace automatically at registration.
model Workspace {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  WorkspaceMember[]
  projects Project[]
}

enum DiscoveryStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

// One guided interview per project (the signature feature). The session
// tracks lifecycle; the answers hold the founder's actual input.
model DiscoverySession {
  id          String          @id @default(uuid())
  status      DiscoveryStatus @default(ACTIVE)
  startedAt   DateTime        @default(now())
  completedAt DateTime?

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String  @unique // one session per project in V1

  answers DiscoveryAnswer[]
}

// One answer per question per session. `answer` is JSONB: today it's
// { "text": "..." }, later AI follow-ups can add structure without a
// schema migration — exactly what JSONB is for.
model DiscoveryAnswer {
  id           String   @id @default(uuid())
  questionId   String // stable key from the question bank (e.g. "problem.who")
  questionText String // snapshot, so old answers survive question-bank edits
  module       String // interview module, e.g. "problem", "customer"
  answer       Json
  answeredAt   DateTime @default(now())

  session   DiscoverySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String

  // Answering the same question again replaces the answer (upsert target).
  @@unique([sessionId, questionId])
}

// The core domain object: everything in Fritlow lives inside a project,
// and every project lives inside a workspace (the tenancy rule).
model Project {
  id          String        @id @default(uuid())
  name        String
  oneLineIdea String
  category    String?
  status      ProjectStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdById String

  discoverySession DiscoverySession?

  @@index([workspaceId])
}

// Join table between User and Workspace, carrying the user's role.
model WorkspaceMember {
  id          String        @id @default(uuid())
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  // A user can only be a member of a given workspace once.
  @@unique([userId, workspaceId])
}

// Long-lived session tokens. Only a SHA-256 hash is stored — if the DB
// leaks, the tokens themselves remain unusable.
model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId])
}

// Single-use tokens for the forgot-password flow, also stored hashed.
model PasswordResetToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId])
}
