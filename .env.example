# Copy this file to .env and fill in real values. Never commit .env.

# Postgres connection strings (from Neon: Dashboard -> Connect).
# DATABASE_URL = pooled endpoint (host contains "-pooler") — used by the app.
# DIRECT_DATABASE_URL = same string without "-pooler" — used by prisma migrate/studio.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/DBNAME?sslmode=require"
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/DBNAME?sslmode=require"

# Server
NODE_ENV=development
PORT=4000

# Auth — generate a strong secret with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET="replace-with-a-long-random-string-at-least-32-chars"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS=30

# AI layer — get a key at https://console.anthropic.com (Settings -> API keys).
# Leave empty to run without AI (AI endpoints return 503).
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=""
AI_MODEL="claude-opus-4-8"

# Email delivery (Brevo) — get a key at https://app.brevo.com (Settings -> SMTP & API -> API keys).
# Leave empty to run without email: sends are skipped and tokens are logged in dev.
BREVO_API_KEY=""
# Sender identity — the address (or its domain) must be verified in Brevo.
EMAIL_FROM_ADDRESS="no-reply@fritlow.com"
EMAIL_FROM_NAME="Fritlow"
# Frontend base URL used for the links inside emails (verify-email / reset-password pages)
APP_URL="http://localhost:3000"

# Frontend origins allowed to call the API with cookies (comma-separated)
CORS_ORIGIN="http://localhost:3000"
# Set to true in production (HTTPS) — marks the refresh cookie Secure + SameSite=None
COOKIE_SECURE=false
