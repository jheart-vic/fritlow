# Copy this file to .env and fill in real values. Never commit .env.

# Postgres connection string (from Neon: Dashboard -> Connect -> Connection string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Server
NODE_ENV=development
PORT=4000

# Auth — generate a strong secret with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET="replace-with-a-long-random-string-at-least-32-chars"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS=30

# AI layer — get a key at https://console.anthropic.com (Settings -> API keys).
# Leave empty to run without AI (AI endpoints return 503).
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=""
AI_MODEL="claude-opus-4-8"

# Frontend origins allowed to call the API with cookies (comma-separated)
CORS_ORIGIN="http://localhost:3000"
# Set to true in production (HTTPS) — marks the refresh cookie Secure + SameSite=None
COOKIE_SECURE=false
